rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }
    
    function isAdmin() { 
      // Using get() to check role in the users collection
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['admin', 'guardian'];
    }

    function isValidNotice(data) {
      return data.keys().hasAll(['title', 'content', 'date', 'category']) &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 10000 &&
             data.category in ['important', 'event', 'info'];
    }

    function isValidDailyLog(data) {
      return data.keys().hasAll(['title', 'time', 'date']) &&
             data.title is string && data.title.size() <= 200 &&
             data.time is string && data.time.size() <= 50;
    }

    function isValidMeal(data) {
      return data.keys().hasAll(['menuName', 'date']) &&
             data.menuName is string && data.menuName.size() <= 200;
    }

    function isValidGalleryItem(data) {
      return data.keys().hasAll(['title', 'imageUrl', 'date']) &&
             data.title is string && data.title.size() <= 200;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['targetId', 'authorId', 'content', 'timestamp']) &&
             data.authorId == request.auth.uid &&
             data.content is string && data.content.size() <= 1000;
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'contact', 'message', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.contact is string && data.contact.size() <= 100 &&
             data.message is string && data.message.size() <= 5000;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'guardian';
      allow update: if (isOwner(userId) && isValidUser(incoming()) && 
                        incoming().role == existing().role && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'guardianFor'])) || 
                    isAdmin();
      allow delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin() && isValidNotice(incoming());
    }

    match /daily_logs/{logId} {
      allow read: if true;
      allow write: if isAdmin() && isValidDailyLog(incoming());
    }

    match /meals/{mealId} {
      allow read: if true;
      allow write: if isAdmin() && isValidMeal(incoming());
    }

    match /gallery/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidGalleryItem(incoming());
      allow update, delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidComment(incoming());
      allow update: if isOwner(existing().authorId) && isValidComment(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['content', 'timestamp']);
      allow delete: if isOwner(existing().authorId) || isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(incoming());
      allow read: if isAdmin();
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
      allow delete: if isAdmin();
    }
  }
}
